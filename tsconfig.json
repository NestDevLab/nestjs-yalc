{
  "compilerOptions": {
    "composite": true,
    "alwaysStrict": true,
    "strict": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "strictBindCallApply": true,
    "strictPropertyInitialization": true,
    "strictNullChecks": true,
    "noImplicitAny": true,
    "noUnusedLocals": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "var/dist",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "skipLibCheck": true,
    "allowJs": true,
    "sourceMap": true,
    "incremental": true,
    "importHelpers": true,
    "isolatedModules": true,
    "preserveConstEnums": true,
    "useDefineForClassFields": false,
    "emitDeclarationOnly": false,
    "paths": {
      "@nestjs-yalc/api-strategy": [
        "./api-strategy/src/index.ts"
      ],
      "@nestjs-yalc/api-strategy/*": [
        "./api-strategy/src/*"
      ],
      "@nestjs-yalc/app": [
        "./app/src/index.ts"
      ],
      "@nestjs-yalc/app/*": [
        "./app/src/*"
      ],
      "@nestjs-yalc/crud-gen": [
        "./crud-gen/src/index.ts"
      ],
      "@nestjs-yalc/crud-gen/*": [
        "./crud-gen/src/*"
      ],
      "@nestjs-yalc/database": [
        "./database/src/index.ts"
      ],
      "@nestjs-yalc/database/*": [
        "./database/src/*"
      ],
      "@nestjs-yalc/aws-helpers": [
        "./aws-helpers/src/index.ts"
      ],
      "@nestjs-yalc/aws-helpers/*": [
        "./aws-helpers/src/*"
      ],
      "@nestjs-yalc/data-loader": [
        "./data-loader/src/index.ts"
      ],
      "@nestjs-yalc/data-loader/*": [
        "./data-loader/src/*"
      ],
      "@nestjs-yalc/errors": [
        "./errors/src/index.ts"
      ],
      "@nestjs-yalc/errors/*": [
        "./errors/src/*"
      ],
      "@nestjs-yalc/event-manager": [
        "./event-manager/src/index.ts"
      ],
      "@nestjs-yalc/event-manager/*": [
        "./event-manager/src/*"
      ],
      "@nestjs-yalc/field-middleware": [
        "./field-middleware/src/index.ts"
      ],
      "@nestjs-yalc/field-middleware/*": [
        "./field-middleware/src/*"
      ],
      "@nestjs-yalc/graphql": [
        "./graphql/src/index.ts"
      ],
      "@nestjs-yalc/graphql/*": [
        "./graphql/src/*"
      ],
      "@nestjs-yalc/interfaces": [
        "./interfaces/src/index.ts"
      ],
      "@nestjs-yalc/interfaces/*": [
        "./interfaces/src/*"
      ],
      "@nestjs-yalc/logger": [
        "./logger/src/index.ts"
      ],
      "@nestjs-yalc/logger/*": [
        "./logger/src/*"
      ],
      "@nestjs-yalc/utils": [
        "./utils/src/index.ts"
      ],
      "@nestjs-yalc/utils/*": [
        "./utils/src/*"
      ],
      "@nestjs-yalc/jest": [
        "./jest/src/index.ts"
      ],
      "@nestjs-yalc/jest/*": [
        "./jest/src/*"
      ],
      "@nestjs-yalc/types": [
        "./types/src/index.d.ts"
      ],
      "@nestjs-yalc/types-extends/*": [
        "./types-extends/src/*"
      ],
      "@nestjs-yalc/types/*": [
        "./types/src/*"
      ],
      "@nestjs-yalc/types-extends": [
        "./types-extends/src/index.d.ts"
      ],
      "@nestjs-yalc/kafka": [
        "./kafka/src/index.ts"
      ],
      "@nestjs-yalc/kafka/*": [
        "./kafka/src/*"
      ],
      "@nestjs-yalc/skeleton-module": [
        "./examples/skeleton/module/src/index.ts"
      ],
      "@nestjs-yalc/skeleton-module/*": [
        "./examples/skeleton/module/src/*"
      ],
      "nestjs-yalc": [
        "./types/src/index.d.ts"
      ],
      "nestjs-yalc/*": [
        "./types/src/*"
      ],
      "@nestjs-yalc/omnikernel-module": [
        "./examples/omnikernel/module/src/index.ts"
      ],
      "@nestjs-yalc/omnikernel-module/*": [
        "./examples/omnikernel/module/src/*"
      ]
    },
    "types": [
      "node",
      "fast-redact"
    ]
  },
  "include": [
    "./**/src/**/*.ts"
  ],
  "exclude": [
    "**/node_modules",
    "kafka",
    "examples",
    "test",
    "**/__mocks__",
    "**/*.spec.ts",
    "**/*.test.ts",
    "var"
  ],
  "ts-node": {
    "transpileOnly": true,
    "experimentalSpecifierResolution": "node",
    "files": true,
    "esm": true,
    "swc": true
  }
}
