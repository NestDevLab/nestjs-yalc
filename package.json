{
  "name": "@nestjs-yalc/framework",
  "type": "module",
  "version": "1.3.2",
  "description": "NestJS - Yet Another Library Collection",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NestDevLab/nestjs-yalc.git"
  },
  "bugs": {
    "url": "https://github.com/NestDevLab/nestjs-yalc/issues"
  },
  "homepage": "https://github.com/NestDevLab/nestjs-yalc#readme",
  "scripts": {
    "ci:checks": "npm run lint && npm run build && npm run test:cov && npm run test:e2e",
    "prebuild": "node ./scripts/clean-dist.mjs",
    "build": "tsc --project ./tsconfig.json",
    "postbuild": "node ./build-dist.mjs",
    "build:watch": "tsc-watch",
    "lint": "npm run lint:no-fix -- --fix",
    "lint:no-fix": "eslint -c eslint.config.mjs \"**/src/**/*.ts\" --max-warnings=0",
    "lint:path": "eslint -c eslint.config.mjs $npm_config_lintpath\"/**/*.ts\" --max-warnings=0",
    "test": "NODE_OPTIONS=\"--experimental-vm-modules --experimental-import-meta-resolve \" npx jest ",
    "test:watch": "npm run test -- --watch",
    "test:debug": "NODE_OPTIONS=\"--experimental-vm-modules --experimental-import-meta-resolve --inspect-brk\" npx jest --runInBand --watch --no-cache ",
    "test:cov": "npm run test -- --coverage",
    "test:cov:watch": "npm run test -- --coverage --watch",
    "test:cov:serve": "npx http-server -c-1 ./var/coverage/",
    "test:cov:clear": "npm run test:clear && rimraf ./var/coverage/",
    "test:clear": "node node_modules/.bin/jest --clearCache",
    "test:e2e": "npm run test:e2e:examples",
    "test:e2e:examples": "npm run test:e2e:skeleton && npm run test:e2e:omnikernel && npm run test:e2e:task",
    "test:e2e:skeleton": "npm run test:e2e --prefix examples/skeleton/app",
    "test:e2e:omnikernel": "npm run test:e2e --prefix examples/omnikernel/app",
    "test:e2e:task": "npm run test:e2e --prefix examples/task/app",
    "pack:dry-run": "npm run build && node ./scripts/pack-public-packages.mjs",
    "publish:dry-run": "npm run build && node ./scripts/publish-public-packages.mjs --dry-run --skip-existing",
    "publish:public": "npm run build && node ./scripts/publish-public-packages.mjs",
    "publish:public:ci": "npm run build && node ./scripts/publish-public-packages.mjs --skip-existing --provenance",
    "smoke:public:tarball": "npm run build && node ./scripts/smoke-public-packages.mjs --source=tarball",
    "smoke:public:registry": "node ./scripts/smoke-public-packages.mjs --source=registry",
    "changeset": "changeset",
    "changeset:status": "changeset status",
    "version:packages": "changeset version && npm install --package-lock-only --ignore-scripts",
    "examples:export": "node ./scripts/export-public-examples.mjs",
    "examples:mirror": "node ./scripts/sync-public-example-mirrors.mjs",
    "examples:mirror:dry-run": "node ./scripts/sync-public-example-mirrors.mjs --dry-run",
    "test:vscode": "node test.js ",
    "npm:update:onlylock": "npm update --package-lock-only",
    "npm:outdated": "npm outdated",
    "ncu:interactive": "npx -y npm-check-updates -i",
    "ncu": "npx -y npm-check-updates -u"
  },
  "author": "",
  "license": "MIT",
  "workspaces": [
    "app",
    "crud-gen",
    "api-strategy",
    "aws-helpers",
    "data-loader",
    "database",
    "errors",
    "event-manager",
    "field-middleware",
    "graphql",
    "interfaces",
    "jest",
    "jest/src/config",
    "kafka",
    "logger",
    "observability",
    "types",
    "types-extends",
    "utils"
  ],
  "peerDependencies": {
    "@nestjs/apollo": "^13.2.5",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^11.1.19",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.19",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/graphql": "^13.2.5",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/platform-fastify": "^11.1.19",
    "@nestjs/swagger": "^11.3.0",
    "@nestjs/typeorm": "^11.0.1",
    "axios": "^1.15.0",
    "nestjs-cls": "^6.2.0"
  },
  "dependencies": {
    "@apollo/server": "^5.5.0",
    "@apollo/subgraph": "^2.13.3",
    "@as-integrations/express5": "^1.1.2",
    "@aws-sdk/client-ssm": "^3.1032.0",
    "@fastify/cookie": "^11.0.2",
    "@jorgebodega/typeorm-seeding": "^7.1.0",
    "@kafkajs/confluent-schema-registry": "^4.0.8",
    "@nestjs/microservices": "^11.1.19",
    "@types/node-fetch": "^2.6.13",
    "amqplib": "^1.0.3",
    "aws-lambda-fastify": "^2.2.0",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cli-color": "^2.0.4",
    "commander": "^14.0.3",
    "csurf": "^1.11.0",
    "dataloader": "^2.2.3",
    "decimal.js": "^10.6.0",
    "fast-redact": "^3.5.0",
    "google-libphonenumber": "^3.2.44",
    "joi": "^18.1.2",
    "lodash": "^4.18.1",
    "lodash-es": "^4.18.1",
    "mobile-detect": "^1.4.5",
    "mysql2": "^3.22.1",
    "neverthrow": "^8.2.0",
    "node-fetch": "^3.3.2",
    "p-map": "^7.0.4",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pino": "^10.3.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "sofa-api": "^0.18.10",
    "tslib": "^2.8.1",
    "typeorm": "^0.3.28",
    "uuidv4": "^6.2.13"
  },
  "optionalDependencies": {
    "@graphql-tools/wrap": "^11.1.14",
    "encoding": "0.1.13",
    "graphql": "^16.13.2",
    "graphql-type-json": "^0.3.2",
    "mssql": "12.3.1",
    "pg": "8.20.0",
    "pg-cloudflare": "^1.3.0",
    "sqlite3": "5.1.7",
    "typeorm-model-generator": "^0.4.6"
  },
  "overrides": {
    "mysql2": "^3.22.1",
    "typeorm": "^0.3.28",
    "fastify": "5.8.5"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@faker-js/faker": "^10.4.0",
    "@fastify/static": "^9.1.1",
    "@fastify/view": "^11.1.1",
    "@golevelup/ts-jest": "^3.0.0",
    "@jest/globals": "^30.3.0",
    "@nestjs/apollo": "^13.2.5",
    "@nestjs/graphql": "^13.2.5",
    "@nestjs/testing": "^11.1.19",
    "@swc/core": "^1.15.30",
    "@swc/helpers": "^0.5.21",
    "@types/amqplib": "^0.10.8",
    "@types/cli-color": "^2.0.6",
    "@types/lodash": "^4.17.24",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^25.6.0",
    "@types/supertest": "^7.2.0",
    "@types/yargs": "^17.0.35",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "esm": "^3.2.25",
    "get-tsconfig": "^4.14.0",
    "globals": "^17.5.0",
    "graphql": "^16.13.2",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.3.0",
    "prettier": "^3.8.3",
    "sqlite3": "5.1.7",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "tsc-watch": "^7.2.0",
    "typescript": "^6.0.3",
    "yargs": "^18.0.0"
  },
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": "./dist/src/index.js",
    "./*": "./dist/src/*"
  },
  "files": [
    "dist"
  ]
}
