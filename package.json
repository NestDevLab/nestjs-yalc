{
  "name": "@nestjs-yalc/framework",
  "type": "module",
  "version": "1.3.2",
  "description": "NestJS - Yet Another Library Collection",
  "scripts": {
    "ci:checks": "npm run lint && npm run build && npm run test:cov && npm run test:e2e",
    "prebuild": "node ./scripts/clean-dist.mjs",
    "build": "tsc --project ./tsconfig.json",
    "postbuild": "node ./build-dist.mjs",
    "build:watch": "tsc-watch",
    "lint": "npm run lint:no-fix -- --fix",
    "lint:no-fix": "eslint -c .eslintrc.cjs \"**/src/**/*.ts\" --max-warnings=0",
    "lint:path": "eslint -c .eslintrc.cjs $npm_config_lintpath\"/**/*.ts\" --max-warnings=0",
    "test": "NODE_OPTIONS=\"--experimental-vm-modules --experimental-import-meta-resolve \" npx jest ",
    "test:watch": "npm run test -- --watch",
    "test:debug": "NODE_OPTIONS=\"--experimental-vm-modules --experimental-import-meta-resolve --inspect-brk\" npx jest --runInBand --watch --no-cache ",
    "test:cov": "npm run test -- --coverage",
    "test:cov:watch": "npm run test -- --coverage --watch",
    "test:cov:serve": "npx http-server -c-1 ./var/coverage/",
    "test:cov:clear": "npm run test:clear && rimraf ./var/coverage/",
    "test:clear": "node node_modules/.bin/jest --clearCache",
    "test:e2e": "npm run test:e2e --prefix examples/skeleton/app",
    "pack:dry-run": "npm run build && node ./scripts/pack-public-packages.mjs",
    "publish:dry-run": "npm run build && node ./scripts/publish-public-packages.mjs --dry-run",
    "publish:public": "npm run build && node ./scripts/publish-public-packages.mjs",
    "examples:export": "node ./scripts/export-public-examples.mjs",
    "test:vscode": "node test.js ",
    "npm:update:onlylock": "npm update --package-lock-only",
    "npm:outdated": "npm outdated",
    "ncu:interactive": "npx -y npm-check-updates -i",
    "ncu": "npx -y npm-check-updates -u"
  },
  "author": "",
  "license": "MIT",
  "workspaces": [
    "app",
    "crud-gen",
    "api-strategy",
    "aws-helpers",
    "data-loader",
    "database",
    "errors",
    "event-manager",
    "field-middleware",
    "graphql",
    "interfaces",
    "jest",
    "jest/src/config",
    "kafka",
    "logger",
    "types",
    "types-extends",
    "utils"
  ],
  "peerDependencies": {
    "@nestjs/apollo": "^13.2.1",
    "@nestjs/axios": "^1.0.1",
    "@nestjs/common": "^9.4.0",
    "@nestjs/config": "^2.2.0",
    "@nestjs/core": "^9.4.3",
    "@nestjs/event-emitter": "^1.4.1",
    "@nestjs/graphql": "^10.1.7",
    "@nestjs/jwt": "^10.0.1",
    "@nestjs/passport": "^9.0.0",
    "@nestjs/platform-express": "^9.4.3",
    "@nestjs/platform-fastify": "^9.2.1",
    "@nestjs/swagger": "^6.3.0",
    "@nestjs/typeorm": "^9.0.1",
    "axios": "^1.4.0",
    "nestjs-cls": "^3.6.0"
  },
  "dependencies": {
    "@apollo/federation": "^0.38.1",
    "@apollo/subgraph": "^2.3.2",
    "@aws-sdk/client-ssm": "^3.931.0",
    "@fastify/cookie": "^8.3.0",
    "@jorgebodega/typeorm-seeding": "^6.0.1",
    "@kafkajs/confluent-schema-registry": "^3.9.0",
    "@nestjs/microservices": "^9.4.3",
    "@types/node-fetch": "^2.6.2",
    "apollo-server-plugin-base": "^3.7.1",
    "aws-lambda-fastify": "^2.2.0",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cli-color": "^2.0.3",
    "commander": "^10.0.0",
    "csurf": "^1.11.0",
    "dataloader": "^2.2.1",
    "decimal.js": "^10.4.3",
    "google-libphonenumber": "^3.2.32",
    "joi": "^17.9.2",
    "lodash": "^4.17.21",
    "lodash-es": "^4.17.21",
    "mobile-detect": "^1.4.5",
    "mysql2": "^3.9.4",
    "neverthrow": "^8.2.0",
    "node-fetch": "^3.3.0",
    "p-map": "^5.5.0",
    "passport": "^0.6.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pino": "^8.21.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0",
    "sofa-api": "^0.13.0",
    "tslib": "^2.6.3",
    "typeorm": "^0.3.14",
    "uuidv4": "^6.2.13"
  },
  "optionalDependencies": {
    "@graphql-tools/wrap": "^9.3.6",
    "encoding": "0.1.13",
    "graphql": "^16.8.1",
    "graphql-type-json": "^0.3.2",
    "mssql": "12.2.1",
    "pg": "8.20.0",
    "pg-cloudflare": "^1.2.7",
    "sqlite3": "5.1.7",
    "typeorm-model-generator": "^0.4.6"
  },
  "overrides": {
    "mysql2": "^3.9.4",
    "typeorm": "^0.3.14",
    "fastify": "4.18.0"
  },
  "devDependencies": {
    "@faker-js/faker": "^7.6.0",
    "@golevelup/ts-jest": "^0.3.4",
    "@jest/globals": "^29.4.2",
    "@nestjs/apollo": "^10.2.1",
    "@nestjs/graphql": "^10.2.1",
    "@nestjs/testing": "^9.4.3",
    "@swc/core": "^1.3.64",
    "@swc/helpers": "^0.5.1",
    "@types/cli-color": "^2.0.2",
    "@types/lodash": "^4.14.191",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^24.9.1",
    "@types/supertest": "^2.0.16",
    "@types/yargs": "^17.0.32",
    "@typescript-eslint/eslint-plugin": "^7.0.1",
    "@typescript-eslint/parser": "^7.0.1",
    "apollo-server-express": "^3.13.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^8.3.0",
    "eslint-plugin-prettier": "^4.0.0",
    "esm": "^3.2.25",
    "get-tsconfig": "^4.4.0",
    "graphql": "^16.12.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.4.2",
    "prettier": "^2.8.8",
    "supertest": "^6.3.4",
    "ts-jest": "^29.4.5",
    "ts-node": "^10.9.1",
    "tsc-watch": "^6.0.0",
    "typescript": "^5.6.3",
    "yargs": "^17.7.2"
  },
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": "./dist/src/index.js",
    "./*": "./dist/src/*"
  },
  "files": [
    "dist"
  ]
}
