{
  "name": "skeleton-app",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "nest build",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/apps/skeleton-app/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "NODE_OPTIONS=\"--experimental-vm-modules --experimental-import-meta-resolve \" jest --config ./apps/skeleton-app/test/jest-e2e.json"
  },
  "dependencies": {
    "@apollo/server": "^5.5.0",
    "@as-integrations/express5": "^1.1.2",
    "@nestjs-yalc/api-strategy": "file:../../../api-strategy",
    "@nestjs-yalc/app": "file:../../../app",
    "@nestjs-yalc/crud-gen": "file:../../../crud-gen",
    "@nestjs-yalc/data-loader": "file:../../../data-loader",
    "@nestjs-yalc/database": "file:../../../database",
    "@nestjs-yalc/errors": "file:../../../errors",
    "@nestjs-yalc/field-middleware": "file:../../../field-middleware",
    "@nestjs-yalc/framework": "file:../../..",
    "@nestjs-yalc/graphql": "file:../../../graphql",
    "@nestjs-yalc/interfaces": "file:../../../interfaces",
    "@nestjs-yalc/jest": "file:../../../jest",
    "@nestjs-yalc/logger": "file:../../../logger",
    "@nestjs-yalc/skeleton-module": "file:../module",
    "@nestjs-yalc/types": "file:../../../types",
    "@nestjs-yalc/utils": "file:../../../utils",
    "@nestjs/apollo": "^13.2.5",
    "@nestjs/common": "^11.1.19",
    "@nestjs/core": "^11.1.19",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/graphql": "^13.2.5",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/typeorm": "^11.0.1",
    "graphql": "^16.13.2",
    "reflect-metadata": "^0.2.2",
    "rimraf": "^6.1.3",
    "rxjs": "^7.8.2",
    "sqlite3": "^5.1.7",
    "typeorm": "^0.3.28"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.19",
    "@types/express": "^5.0.6",
    "@types/jest": "30.0.0",
    "@types/node": "^25.6.0",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^30.3.0",
    "prettier": "^3.8.3",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-loader": "^9.5.7",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/apps/",
      "<rootDir>/libs/"
    ],
    "moduleNameMapper": {
      "^@skeleton-app/skeleton-base-app(|/.*)$": "<rootDir>/libs/skeleton-base-app/src/$1",
      "^lodash-es$": "lodash"
    }
  }
}
